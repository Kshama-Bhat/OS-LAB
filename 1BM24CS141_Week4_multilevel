Write a C program to simulate multi-level queue scheduling algorithm considering the following scenario. All the processes in the system are divided into two 
categories – system processes and user processes. System processes are to be given higher priority than user processes. Use FCFS scheduling for the processes 
in each queue.

#include<stdio.h>
int main(){
    int n,i,j;
    printf("no of processes:");
    scanf("%d",&n);
    int at[n],bt[n],ct[n],tat[n],wt[n],tp[n];
    int sq[n],uq[n];
    int sc=0,uc=0;
    for(i=0;i<n;i++){
        printf("\nProcess P%d:\n",i+1);
        printf("Arrival Time:");
        scanf("%d",&at[i]);
        printf("Burst Time:");
        scanf("%d",&bt[i]);
        printf("Type (0-System,1-User):");
        scanf("%d",&tp[i]);

        if(tp[i]==0)
            sq[sc++]=i;
        else
            uq[uc++]=i;
    }
    for(i=0;i<sc-1;i++){
        for(j=i+1;j<sc;j++){
            if(at[sq[i]]>at[sq[j]]){
                int t=sq[i];
                sq[i]=sq[j];
                sq[j]=t;
            }
        }
    }
    for(i=0;i<uc-1;i++){
        for(j=i+1;j<uc;j++){
            if(at[uq[i]]>at[uq[j]]){
                int t=uq[i];
                uq[i]=uq[j];
                uq[j]=t;
            }
        }
    }
    int curr=0;
    for(i=0;i<sc;i++){
        int p=sq[i];
        if(curr<at[p])
            curr=at[p];
        curr+=bt[p];
        ct[p]=curr;
        tat[p]=ct[p]-at[p];
        wt[p]=tat[p]-bt[p];
    }
    for(i=0;i<uc;i++){
        int p=uq[i];
        if(curr<at[p])
            curr=at[p];
        curr+=bt[p];
        ct[p]=curr;
        tat[p]=ct[p]-at[p];
        wt[p]=tat[p]-bt[p];
    }
    printf("\nPID\tAT\tBT\tTYPE\tCT\tTAT\tWT\n");
    for(i=0;i<n;i++){
        printf("P%d\t%d\t%d\t%s\t%d\t%d\t%d\n",
        i+1,at[i],bt[i],(tp[i]==0?"SYS":"USER"),ct[i],tat[i],wt[i]);
    }

    return 0;
}
