Write a C program to simulate the following CPU scheduling algorithm to find turnaround time and waiting time - Priority

#include <stdio.h>
#include <limits.h>
int main()
{
    int n,i;
    printf("no of processes: ");
    scanf("%d",&n);
    int at[n],bt[n],pr[n];
    for(int i=0;i<n;i++) {
        printf("PR of P%d: ", i+1);
        scanf("%d", &pr[i]);
        printf("AT of P%d: ", i+1);
        scanf("%d", &at[i]);
        printf("BT of P%d: ", i+1);
        scanf("%d", &bt[i]);
    }
    //for non preemptive
    int done[n],ct[n],tat[n],wt[n];
    for(i=0;i<n;i++) done[i]=0;
    int current_time=0,completed=0,pos;
    while(completed<n)
    {
        int min=INT_MAX; pos=-1;
        for(i=0;i<n;i++)
        {
            if(at[i]<=current_time && done[i]==0)
            {
                if(pr[i]<min)
                {
                    min=pr[i];
                    pos=i;
                }
                else if(pr[i]==min)
                {
                    if(at[i] < at[pos])
                        pos=i;
                }
            }
        }
        if(pos==-1) current_time++;
        else
        {
            current_time+=bt[pos];
            ct[pos]=current_time;
            tat[pos]=ct[pos]-at[pos];
            wt[pos]=tat[pos]-bt[pos];
            done[pos]=1;
            completed++;
        }
    }
    printf("\nNon-Preemptive Priority\n");
    printf("PID\tAT\tBT\tPR\tCT\tTAT\tWT\n");
    for(i=0;i<n;i++)
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
        i+1,at[i],bt[i],pr[i],ct[i],tat[i],wt[i]);
    //preemptive
    int rt[n];
    for(i=0;i<n;i++) rt[i]=bt[i];
    completed=0; current_time=0;
    while(completed<n)
    {
        int min=INT_MAX; pos=-1;
        for(i=0;i<n;i++)
        {
            if(at[i]<=current_time && rt[i]>0)
            {
                if(pr[i]<min)
                {
                    min=pr[i];
                    pos=i;
                }
                else if(pr[i]==min)
                {
                    if(at[i] < at[pos])
                        pos=i;
                }
            }
        }
        if(pos==-1) current_time++;
        else
        {
            rt[pos]--;
            current_time++;
            if(rt[pos]==0)
            {
                ct[pos]=current_time;
                tat[pos]=ct[pos]-at[pos];
                wt[pos]=tat[pos]-bt[pos];
                completed++;
            }
        }
    }
    printf("\nPreemptive Priority\n");
    printf("PID\tAT\tBT\tPR\tCT\tTAT\tWT\n");
    for(i=0;i<n;i++)
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
        i+1,at[i],bt[i],pr[i],ct[i],tat[i],wt[i]);
    return 0;
}
