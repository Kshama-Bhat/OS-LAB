Write a C program to simulate the following CPU scheduling algorithm to find turnaround time and waiting time - Round Robin

#include <stdio.h>
int main()
{
    int n,i;
    printf("no of processes: ");
    scanf("%d",&n);
    int at[n],bt[n],rt[n],ct[n],tat[n],wt[n];
    for(int i=0;i<n;i++) {
        printf("AT of P%d: ", i+1);
        scanf("%d", &at[i]);
        printf("BT of P%d: ", i+1);
        scanf("%d", &bt[i]);
        rt[i]=bt[i];
    }
    int q;
    printf("\ntime quantum: ");
    scanf("%d",&q);
    int completed=0,current_time=0;
    while(completed<n)
    {
        int flag=0;
        for(i=0;i<n;i++)
        {
            if(at[i]<=current_time && rt[i]>0)
            {
                flag=1;
                if(rt[i]>q)
                {
                    current_time+=q;
                    rt[i]-=q;
                }
                else
                {
                    current_time+=rt[i];
                    ct[i]=current_time;
                    tat[i]=ct[i]-at[i];
                    wt[i]=tat[i]-bt[i];
                    rt[i]=0;
                    completed++;
                }
            }
        }
        if(flag==0)
        {
            int min_at=9999;
            for(i=0;i<n;i++)
            {
                if(rt[i]>0 && at[i]<min_at)
                    min_at=at[i];
            }
            current_time=min_at;
        }
    }
    printf("\nPID\tAT\tBT\tCT\tTAT\tWT\n");
    float avg_tat=0, avg_wt=0;
    for(i=0;i<n;i++)
    {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
        i+1,at[i],bt[i],ct[i],tat[i],wt[i]);
        avg_tat += tat[i];
        avg_wt += wt[i];
    }
    printf("\navg tat=%.2f",avg_tat/n);
    printf("\navg wt=%.2f\n",avg_wt/n);

    return 0;
}
